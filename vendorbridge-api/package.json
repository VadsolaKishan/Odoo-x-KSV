{
  "name": "vendorbridge-api",
  "version": "1.0.0",
  "description": "VendorBridge - Procurement & Vendor Management ERP Backend",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon src/app.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/app.js",
    "migrate": "ts-node src/config/migrate.ts",
    "db:clean": "ts-node src/config/clean.ts",
    "db:reset": "ts-node src/config/clean.ts && ts-node src/config/migrate.ts",
    "test": "jest --runInBand --detectOpenHandles --forceExit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^18.19.33",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
